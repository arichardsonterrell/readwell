# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Optional: restrict which frontend origin can call this API
# Leave blank to allow all origins (fine for development)
# Example: ALLOWED_ORIGIN=https://yourusername.github.io
ALLOWED_ORIGIN=

# Port (Render/Railway set this automatically; 3001 is the local default)
PORT=3001
